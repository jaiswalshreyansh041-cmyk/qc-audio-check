{
  "version": 2,
  "buildCommand": "npm run install:all && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/health",     "destination": "/api/index.js" },
    { "source": "/(.*)",       "destination": "/index.html"   }
  ]
}
